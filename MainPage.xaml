<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Ruletka.MainPage"  WidthRequest="950">
    
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1E2F40" Offset="0.0" />
            <GradientStop Color="Black" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>
    
    <ContentPage.Resources>
        <Style x:Key="BottomLineStyle" TargetType="BoxView">
            <Setter Property="HeightRequest" Value="1" />
            <Setter Property="Color" Value="#546373" />
            <Setter Property="HorizontalOptions" Value="Fill" />
        </Style>
    </ContentPage.Resources>


    <ScrollView>

        <StackLayout>

            <!--HEADER-->
            <Grid Background="#0A0F1C" HeightRequest="60" Padding="0,10,0,0">

                <Border Background="#36404A" WidthRequest="200" HeightRequest="40" HorizontalOptions="Start" 
                        VerticalOptions="Center" Margin="5" StrokeShape="RoundRectangle 12" Stroke="SlateGray" StrokeThickness="0.8">

                    <HorizontalStackLayout>
                        <Image Source="ruletka.png" HeightRequest="40" WidthRequest="40" VerticalOptions="Center" Margin="5,0,0,0"/>
                        <Label VerticalOptions="Center" Margin="20,0,0,0" WidthRequest="100" FontAttributes="Bold" FontSize="22" FontFamily="PlayfairDisplay" TextColor="#F9F6EE">Ruletka</Label>
                    </HorizontalStackLayout>
                </Border>

                <Border Background="#36404A" WidthRequest="200" HeightRequest="40" HorizontalOptions="Center" 
                        VerticalOptions="Center" Margin="500,5,5,5" StrokeShape="RoundRectangle 12" Stroke="SlateGray" StrokeThickness="0.8">
                    <HorizontalStackLayout>
                        <Label VerticalOptions="Center" Margin="20,0,0,0" WidthRequest="100" FontAttributes="Bold" FontSize="20" FontFamily="PlayfairDisplay" TextColor="#F9F6EE">Saldo:</Label>
                        <Label VerticalOptions="Center" Margin="20,0,0,0" WidthRequest="100" FontAttributes="Bold" FontSize="20" FontFamily="PlayfairDisplay" x:Name="balance_label"></Label>
                    </HorizontalStackLayout>
                </Border>

                <Border x:Name="AccountBorder" Background="SlateGray" WidthRequest="50" HeightRequest="40" HorizontalOptions="End" 
                    VerticalOptions="Center" Margin="5" StrokeShape="RoundRectangle 12" Stroke="#36404A" StrokeThickness="0.8">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="AccountTapped"/>
                        <PointerGestureRecognizer PointerEntered="AccountHoverEntered" PointerExited="AccountHoverExited"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout x:Name="account">
                        <Image Source="konto.png" HeightRequest="40" WidthRequest="40" VerticalOptions="Center" Margin="5,0,0,0" HorizontalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

            </Grid>
            <BoxView Style="{StaticResource BottomLineStyle}"></BoxView>
            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="650"></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <!--LEWA STRONA-->
                <StackLayout Grid.Column="0" Padding="20">
                    <!--KOŁO RULETKI-->
                    <Border Background="#36404A" StrokeShape="RoundRectangle 12" Stroke="SlateGray" StrokeThickness="0.8" Padding="10" Margin="0,0,0,15">

                        <VerticalStackLayout>

                            <Label Margin="10,10,10,4" FontAttributes="Bold" FontSize="20" FontFamily="PlayfairDisplay" HorizontalOptions="Center" TextColor="#F9F6EE">Koło Ruletki</Label>

                            <!-- GraphicsView – tutaj rysowane jest koło -->
                            <GraphicsView x:Name="WheelView" HeightRequest="340" WidthRequest="340" HorizontalOptions="Center" Margin="0,8,0,8"/>

                            <Label x:Name="result_label"></Label>
                            <!-- Przyciski -->
                            <HorizontalStackLayout HorizontalOptions="Center" Spacing="10" Margin="0,0,0,10">
                                <Button x:Name="SpinButton" Text="▶️ Zakręć kołem" BackgroundColor="Maroon" FontAttributes="Bold" Clicked="OnSpinClicked" TextColor="#F5F5F5">
                                    <Button.GestureRecognizers>
                                        <PointerGestureRecognizer PointerEntered="SpinButton_OnPointerEntered" PointerExited="SpinButton_OnPointerExited"/>
                                    </Button.GestureRecognizers>
                                </Button>

                                <Button Text="⟳ Usuń zakłady" Background="DarkGray"/>
                            </HorizontalStackLayout>

                        </VerticalStackLayout>

                    </Border>
                    <!--ZAKŁADY-->
                    <Border Background="#36404A" StrokeShape="RoundRectangle 12" Stroke="SlateGray" StrokeThickness="0.8" Padding="10">
                        <VerticalStackLayout>
                            <Label Margin="10,10,10,4" FontAttributes="Bold" FontSize="17" FontFamily="PlayfairDisplay" HorizontalOptions="Start" TextColor="#F9F6EE">Zakłady</Label>
                            <Grid RowSpacing="2" ColumnSpacing="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition ></ColumnDefinition>
                                    <ColumnDefinition></ColumnDefinition>
                                    <ColumnDefinition></ColumnDefinition>
                                    <ColumnDefinition></ColumnDefinition>
                                    <ColumnDefinition></ColumnDefinition>
                                    <ColumnDefinition></ColumnDefinition>
                                    <ColumnDefinition></ColumnDefinition>
                                    <ColumnDefinition></ColumnDefinition>
                                    <ColumnDefinition></ColumnDefinition>
                                    <ColumnDefinition></ColumnDefinition>
                                    <ColumnDefinition></ColumnDefinition>
                                    <ColumnDefinition></ColumnDefinition>
                                    <ColumnDefinition></ColumnDefinition>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition ></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                
                                <!--ZIELONE-->
                                <Button Grid.Column="0" Grid.Row="1" Text="0" Background="Green" Padding="0" TextColor="White"></Button>
                                
                                <!--1 KOLUMNA-->
                                <Button Grid.Column="1" Grid.Row="0" Text="3" Background="#B81304" TextColor="White"></Button>
                                <Button Grid.Column="1" Grid.Row="1" Text="2" Background="#242424" TextColor="White"></Button>
                                <Button Grid.Column="1" Grid.Row="2" Text="1" Background="#B81304" TextColor="White"></Button>
                                
                                <!--2 KOLUMNA-->
                                <Button Grid.Column="2" Grid.Row="0" Text="6" Background="#242424" TextColor="White"></Button>
                                <Button Grid.Column="2" Grid.Row="1" Text="5" Background="#B81304" TextColor="White"></Button>
                                <Button Grid.Column="2" Grid.Row="2" Text="4" Background="#242424" TextColor="White"></Button>

                                <!--3 KOLUMNA-->
                                <Button Grid.Column="3" Grid.Row="0" Text="9" Background="#B81304" TextColor="White"></Button>
                                <Button Grid.Column="3" Grid.Row="1" Text="8" Background="#242424" TextColor="White"></Button>
                                <Button Grid.Column="3" Grid.Row="2" Text="7" Background="#B81304" TextColor="White"></Button>

                                <!--4 KOLUMNA-->
                                <Button Grid.Column="4" Grid.Row="0" Text="12" Background="#242424" TextColor="White"></Button>
                                <Button Grid.Column="4" Grid.Row="1" Text="11" Background="#B81304" TextColor="White"></Button>
                                <Button Grid.Column="4" Grid.Row="2" Text="10" Background="#242424" TextColor="White"></Button>

                                <!--5 KOLUMNA-->
                                <Button Grid.Column="5" Grid.Row="0" Text="15" Background="#B81304" TextColor="White"></Button>
                                <Button Grid.Column="5" Grid.Row="1" Text="14" Background="#242424" TextColor="White"></Button>
                                <Button Grid.Column="5" Grid.Row="2" Text="13" Background="#B81304" TextColor="White"></Button>

                                <!--6 KOLUMNA-->
                                <Button Grid.Column="6" Grid.Row="0" Text="18" Background="#242424" TextColor="White"></Button>
                                <Button Grid.Column="6" Grid.Row="1" Text="17" Background="#B81304" TextColor="White"></Button>
                                <Button Grid.Column="6" Grid.Row="2" Text="16" Background="#242424" TextColor="White"></Button>

                                <!--7 KOLUMNA-->
                                <Button Grid.Column="7" Grid.Row="0" Text="21" Background="#B81304" TextColor="White"></Button>
                                <Button Grid.Column="7" Grid.Row="1" Text="20" Background="#242424" TextColor="White"></Button>
                                <Button Grid.Column="7" Grid.Row="2" Text="19" Background="#B81304" TextColor="White"></Button>

                                <!--8 KOLUMNA-->
                                <Button Grid.Column="8" Grid.Row="0" Text="24" Background="#242424" TextColor="White"></Button>
                                <Button Grid.Column="8" Grid.Row="1" Text="23" Background="#B81304" TextColor="White"></Button>
                                <Button Grid.Column="8" Grid.Row="2" Text="22" Background="#242424" TextColor="White"></Button>

                                <!--9 KOLUMNA-->
                                <Button Grid.Column="9" Grid.Row="0" Text="27" Background="#B81304" TextColor="White"></Button>
                                <Button Grid.Column="9" Grid.Row="1" Text="26" Background="#242424" TextColor="White"></Button>
                                <Button Grid.Column="9" Grid.Row="2" Text="25" Background="#B81304" TextColor="White"></Button>

                                <!--10 KOLUMNA-->
                                <Button Grid.Column="10" Grid.Row="0" Text="30" Background="#242424" TextColor="White"></Button>
                                <Button Grid.Column="10" Grid.Row="1" Text="29" Background="#B81304" TextColor="White"></Button>
                                <Button Grid.Column="10" Grid.Row="2" Text="28" Background="#242424" TextColor="White"></Button>

                                <!--11 KOLUMNA-->
                                <Button Grid.Column="11" Grid.Row="0" Text="33" Background="#B81304" TextColor="White"></Button>
                                <Button Grid.Column="11" Grid.Row="1" Text="32" Background="#242424" TextColor="White"></Button>
                                <Button Grid.Column="11" Grid.Row="2" Text="31" Background="#B81304" TextColor="White"></Button>

                                <!--12 KOLUMNA-->
                                <Button Grid.Column="12" Grid.Row="0" Text="36" Background="#242424" TextColor="White"></Button>
                                <Button Grid.Column="12" Grid.Row="1" Text="35" Background="#B81304" TextColor="White"></Button>
                                <Button Grid.Column="12" Grid.Row="2" Text="34" Background="#242424" TextColor="White"></Button>
                            </Grid>
                            
                            <!--RESZTA ZAKŁADÓW (kolory)-->
                            <HorizontalStackLayout HorizontalOptions="Center" Margin="10">
                                <Button Text="Czerwony" WidthRequest="150" Margin="5" TextColor="White" Background="#B81304"></Button>
                                <Button Text="Czarny" WidthRequest="150" Margin="5" TextColor="White" Background="#242424"></Button>
                            </HorizontalStackLayout>
                            
                        </VerticalStackLayout>
                    </Border>

                </StackLayout>
                <!--PRAWA STRONA-->
                <StackLayout Grid.Column="1" Padding="20">
                    <!--ŻETONY-->
                    <Border Background="#36404A" StrokeShape="RoundRectangle 12" Stroke="SlateGray" StrokeThickness="0.8" Padding="10">
                        <VerticalStackLayout>
                            <Label Margin="10,10,10,4" FontAttributes="Bold" FontSize="17" FontFamily="PlayfairDisplay" HorizontalOptions="Start" TextColor="#F9F6EE">Żetony</Label>

                            <HorizontalStackLayout>
                                
                                <Border StrokeShape="RoundRectangle 50" Stroke="Black" StrokeThickness="0.6" HeightRequest="45" VerticalOptions="Center" Margin="3">
                                    <Button Text="1$" WidthRequest="70" Background="#8342B8" TextColor="White"></Button>
                                </Border>
                                
                                <Border StrokeShape="RoundRectangle 50" Stroke="Black" StrokeThickness="0.6" HeightRequest="45" VerticalOptions="Center"  Margin="3">
                                    <Button Text="5$" WidthRequest="70" Background="#B0130B" TextColor="White"></Button>
                                </Border>
                                
                                <Border StrokeShape="RoundRectangle 50" Stroke="Black" StrokeThickness="0.6" HeightRequest="45" VerticalOptions="Center"  Margin="3">
                                    <Button Text="25$" WidthRequest="70" Background="#22740B" TextColor="White"></Button>
                                </Border>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout>
                                
                                <Border StrokeShape="RoundRectangle 50" Stroke="Black" StrokeThickness="0.6" HeightRequest="45" VerticalOptions="Center" Margin="3">
                                    <Button Text="50$" WidthRequest="70" Background="#BFAC00" TextColor="White"></Button>
                                </Border>
                                
                                <Border StrokeShape="RoundRectangle 50" Stroke="Black" StrokeThickness="0.6" HeightRequest="45" VerticalOptions="Center" Margin="3">
                                    <Button Text="100$" WidthRequest="70" Background="#CC66D0" TextColor="White"></Button>
                                </Border>
                                
                                <Border StrokeShape="RoundRectangle 50" Stroke="Black" StrokeThickness="0.6" HeightRequest="45" VerticalOptions="Center" Margin="3">
                                    <Button Text="500$" WidthRequest="70" Background="#E86C00" TextColor="White"></Button>
                                </Border>
                                
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                    <!--ZAKŁAD-INFO-->
                    <Border Background="#36404A" StrokeShape="RoundRectangle 12" Stroke="SlateGray" StrokeThickness="0.8" Padding="10" Margin="0,15,0,0">
                        <VerticalStackLayout>
                            <Label Margin="10,10,10,4" FontAttributes="Bold" FontSize="17" FontFamily="PlayfairDisplay" HorizontalOptions="Start" TextColor="#F9F6EE">Obecny zakład</Label>

                            <Border Background="LightGray" StrokeShape="RoundRectangle 12" Stroke="#FFFFFF" StrokeThickness="0.8" Margin="0,5,0,0">
                                <HorizontalStackLayout HeightRequest="30">
                                    <Label x:Name="current_color_label"></Label>
                                    <Label x:Name="current_color_bet_label"></Label>
                                </HorizontalStackLayout>
                            </Border>

                            <Border Background="LightGray" StrokeShape="RoundRectangle 12" Stroke="#FFFFFF" StrokeThickness="0.8" Margin="0,10,0,0">
                                <HorizontalStackLayout HeightRequest="30">
                                    <Label x:Name="current_number_label"></Label>
                                    <Label x:Name="current_number_bet_label"></Label>
                                </HorizontalStackLayout>
                            </Border>
                            <BoxView Style="{StaticResource BottomLineStyle}" Margin="0,10,0,0" Color="Black" HeightRequest="2"></BoxView>

                            <HorizontalStackLayout>
                                <Label FontSize="16" FontFamily="PlayfairDisplay" HorizontalOptions="Start" Margin="4" TextColor="#F9F6EE">Łączny zakład:</Label>
                                <Label x:Name="total_current_bet"></Label>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!--STATYSTYKI GRY-->
                    <Border Background="#36404A" StrokeShape="RoundRectangle 12" Stroke="SlateGray" StrokeThickness="0.8" Padding="10" Margin="0,15,0,0">
                        <VerticalStackLayout>
                            <Label Margin="10,10,10,4" FontAttributes="Bold" FontSize="17" FontFamily="PlayfairDisplay" HorizontalOptions="Start" TextColor="#F9F6EE">Statystyki gry</Label>

                            <HorizontalStackLayout>
                                <Label FontFamily="PlayfairDisplay" FontSize="16" Margin="20,0,0,0" TextColor="#F9F6EE">Zagrane gry:</Label>
                                <Label x:Name="games_playes_label"></Label>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout>
                                <Label FontFamily="PlayfairDisplay" FontSize="16" Margin="20,0,0,0" TextColor="#F9F6EE">Łączcna wygrana: </Label>
                                <Label x:Name="total_cash_won_label"></Label>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout>
                                <Label FontFamily="PlayfairDisplay" FontSize="16" Margin="20,0,0,0" TextColor="#F9F6EE">Wygrane gry:</Label>
                                <Label x:Name="games_won_label"></Label>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                    
                    <!--HISTORIA-->
                    <Border Background="#36404A" StrokeShape="RoundRectangle 12" Stroke="SlateGray" StrokeThickness="0.8" Padding="10" Margin="0,15,0,0">
                        <VerticalStackLayout>
                            <Label  Margin="10,10,10,4" FontAttributes="Bold" FontSize="17" FontFamily="PlayfairDisplay" HorizontalOptions="Start" TextColor="#F9F6EE">Ostatnie zakłady</Label>
                            
                        </VerticalStackLayout>
                    </Border>   
                </StackLayout>
            </Grid>

        </StackLayout>
    </ScrollView>

</ContentPage>
